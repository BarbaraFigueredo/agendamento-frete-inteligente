# ── Django ────────────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-something-random-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=freight_db
POSTGRES_USER=freight_user
POSTGRES_PASSWORD=freight_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
